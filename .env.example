# ============================================================
# .env.example — FILE MẪU CẤU HÌNH MÔI TRƯỜNG
# ============================================================
# File này ĐƯỢC PHÉP commit vào Git — không chứa giá trị thật.
# Khi setup môi trường mới:
#   cp .env.example .env
# Sau đó điền giá trị thật vào file .env.
# ============================================================

# ---- Server ----
SERVER_PORT=8081

# ---- Database ----
DB_URL=jdbc:postgresql://localhost:5432/social_db
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# ---- JPA ----
# dev: update | staging/prod: validate
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# ---- File Upload ----
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5MB
MAX_REQUEST_SIZE=20MB

# ---- HikariCP Connection Pool ----
HIKARI_MAX_POOL_SIZE=30
HIKARI_MIN_IDLE=10
HIKARI_CONN_TIMEOUT=10000

# ---- Tomcat Thread Pool ----
TOMCAT_MAX_THREADS=200
TOMCAT_ACCEPT_COUNT=100
